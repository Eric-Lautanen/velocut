# VeloCut .gitignore

# Build output
/target/
/debug/
/release/

# Rust
*.rs.bk
*.rlib
*.rmeta
*.d
*.exp
*.lib
*.pdb

# FFmpeg static build artifacts
/c/ffmpeg-velocut/
*.a
*.dll.a

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# App runtime artifacts
*.log
velocut_*
!velocut-core/**
!velocut-media/**
!velocut-ui/**
!assets/**
!*.md
!*.toml
!*.lock

# MSYS2 / MINGW64
/msys64/
/mingw64/

# Temp files
*.wav.tmp
*.tmp
